# Main app
:80 {
    reverse_proxy app:2000 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
    }
}

# IB Client Portal Gateway — separate subdomain so login page paths resolve naturally
http://ib.oanda.onlinesolution24.com {
    reverse_proxy ib-gateway:5000 {
        transport http {
            tls_insecure_skip_verify
        }
    }
}
