{
    admin 0.0.0.0:2019 {
        origins caddy:2019 localhost:2019 127.0.0.1:2019
    }
}

oanda.onlinesolution24.com {
    # IB Client Portal Gateway — route gateway-specific paths directly
    # These paths don't overlap with app routes (/api/*, /settings, /signals, etc.)
    @gateway path /sso/* /ssodh/* /oauth/* /portal/* /portal.proxy/* /tickle /demo/* /credential.recovery/* /css/* /scripts/* /images/* /lib/* /en/* /fonts/* /Universal/*
    handle @gateway {
        reverse_proxy https://ib-gateway:5000 {
            transport http {
                tls
                tls_insecure_skip_verify
                versions 1.1
            }
            # Strip upstream cache headers to prevent stale JS after gateway restarts
            header_down -ETag
            header_down -Last-Modified
            header_down Cache-Control "no-store"
        }
    }

    # Everything else goes to the Next.js app
    handle {
        reverse_proxy app:2000 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
        }
    }
}
